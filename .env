# Young Eagles PWA - Local Development Configuration

# Force the PWA to use local API server for development
VITE_FORCE_LOCAL_API=true

# Local API server URL (your backend)
VITE_API_LOCAL_URL=http://localhost:3001

# Production API server URL
VITE_API_BASE_URL=https://youngeagles-api-server.up.railway.app

# WebSocket server URLs
VITE_API_WS_URL=wss://youngeagles-api-server.up.railway.app
VITE_WS_LOCAL_URL=http://localhost:3002

# Development flags
VITE_DEBUG_MODE=true
VITE_ENABLE_SW=false

# Feature flags for development
VITE_ENABLE_PUSH_NOTIFICATIONS=true
VITE_ENABLE_OFFLINE_MODE=false
VITE_ENABLE_ANALYTICS=false

# Deprecated - keeping for compatibility
VITE_API_URL=http://localhost:3001
